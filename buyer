              <div class="result-stat"><div class="stat-num" style="color:#52c41a">{{ mod4.result.success }}</div><div class="stat-label">成功</div></div>
              <div class="result-stat"><div class="stat-num" style="color:#ff4d4f">{{ mod4.result.failed }}</div><div class="stat-label">失败</div></div>
            </div>
            <div class="alert alert-info" style="margin-top:12px">
              💡 请在对话中发送指令执行实际写入操作。
            </div>
          </div>
        </div>
      </div>

      <!-- Module 5: 质检验货数据 -->
      <div v-if="currentModule === 4" class="module-content">
        <div class="page-header">
          <h2>质检验货数据</h2>
          <p>批量录入质检验货数据，支持尾数解析</p>
        </div>

        <div class="steps">
          <div class="step" :class="{ active: mod5.step === 1, done: mod5.step > 1 }">
            <div class="step-icon">{{ mod5.step > 1 ? '✓' : '1' }}</div>
            <div class="step-text">选择目标表</div>
          </div>
          <div class="step" :class="{ active: mod5.step === 2, done: mod5.step > 2 }">
            <div class="step-icon">{{ mod5.step > 2 ? '✓' : '2' }}</div>
            <div class="step-text">输入数据</div>
          </div>
          <div class="step" :class="{ active: mod5.step === 3, done: mod5.step > 3 }">
            <div class="step-icon">{{ mod5.step > 3 ? '✓' : '3' }}</div>
            <div class="step-text">解析校验</div>
          </div>
          <div class="step" :class="{ active: mod5.step === 4 }">
            <div class="step-icon">{{ mod5.step >= 4 ? '✓' : '4' }}</div>
            <div class="step-text">确认登记</div>
          </div>
        </div>

        <!-- Target table -->
        <div class="card">
          <div class="card-title">目标飞书表</div>
          <select class="form-select" v-model="mod5.selectedTable">
            <option value="">-- 请选择目标飞书表 --</option>
            <option v-for="t in presetTables" :key="t.token" :value="t.token">{{ t.name }}</option>
          </select>
        </div>

        <!-- Input -->
        <div class="card">
          <div class="card-title">输入数据</div>
          <div class="alert alert-info">
            📝 每行一条记录，格式为：<strong>SU-{合同号}-{SKU}-{数量}套</strong>，可带尾数
          </div>
          <div class="alert alert-warning">
            💡 示例：<br>
            <code style="display:block;margin-top:4px;line-height:1.8">
SU-26206-2CD149Z-315套<br>
SU-26208-2CD148B-259 尾数6套<br>
SU-26206-2CD149B-250套，尾数15套</code>
          </div>
          <textarea class="form-textarea" v-model="mod5.inputText" rows="10" placeholder="在此粘贴数据，每行一条..."></textarea>
        </div>

        <!-- Validation -->
        <div class="card" v-if="mod5.validationResults.length > 0">
          <div class="card-title">校验结果</div>
          <div class="result-stats" style="margin-bottom:16px">
            <div class="result-stat"><div class="stat-num" style="color:#52c41a">{{ mod5.validCount }}</div><div class="stat-label">通过</div></div>
            <div class="result-stat"><div class="stat-num" style="color:#ff4d4f">{{ mod5.invalidCount }}</div><div class="stat-label">失败</div></div>
            <div class="result-stat"><div class="stat-num">{{ mod5.validationResults.length }}</div><div class="stat-label">总计</div></div>
          </div>
          <div class="validation-list">
            <div class="validation-item" v-for="(item, i) in mod5.validationResults" :key="i"
                 :class="item.valid ? 'success' : 'error'">
              <span class="line-num">{{ i + 1 }}</span>
              <span class="line-content">{{ item.raw }}</span>
              <span class="status">
                <span v-if="item.valid" class="tag tag-success">
                  ✅ 合同:{{ item.contract }} SKU:{{ item.sku }} 数量:{{ item.qty }}套
                  <span v-if="item.remainder" style="color:#faad14"> | 尾数:{{ item.remainder }}套</span>
                </span>
                <span v-else class="tag tag-error">❌ {{ item.error }}</span>
              </span>
            </div>
          </div>
        </div>

        <!-- Actions -->
        <div class="card">
          <div class="card-title">操作区</div>
          <div class="btn-group">
            <button class="btn btn-primary" @click="mod5Parse" :disabled="!mod5.inputText.trim()">
              🔍 解析
            </button>
            <button class="btn btn-success" @click="mod5Validate" :disabled="mod5.validationResults.length === 0">
              ✅ 校验
            </button>
            <button class="btn btn-warning" @click="mod5Confirm" :disabled="mod5.validCount === 0 || !mod5.selectedTable">
              📤 确认登记
            </button>
            <button class="btn" @click="mod5Reset">🔄 重置</button>
          </div>
        </div>

        <!-- Result -->
        <div v-if="mod5.result" class="card">
          <div class="card-title">登记结果</div>
          <div class="result-panel">
            <div class="result-stats">
              <div class="result-stat"><div class="stat-num" style="color:#52c41a">{{ mod5.result.success }}</div><div class="stat-label">成功</div></div>
              <div class="result-stat"><div class="stat-num" style="color:#ff4d4f">{{ mod5.result.failed }}</div><div class="stat-label">失败</div></div>
            </div>
            <div v-if="mod5.remainderSummary.length > 0" style="margin-top:12px">
              <div style="font-size:13px;font-weight:600;margin-bottom:8px;color:#faad14">📦 尾数信息汇总：</div>
              <div class="validation-list">
                <div class="validation-item success" v-for="(r, i) in mod5.remainderSummary" :key="i">
                  <span class="line-num">{{ i + 1 }}</span>
                  <span class="line-content">合同:{{ r.contract }} SKU:{{ r.sku }} → 尾数:{{ r.remainder }}套</span>
                </div>
              </div>
            </div>
            <div class="alert alert-info" style="margin-top:12px">
              💡 请在对话中发送指令执行实际写入操作。
            </div>
          </div>
        </div>
      </div>

    </div>
  </div>
</div>

<script>
const { createApp, reactive, ref, computed } = Vue;

const app = createApp({
  setup() {
    const sidebarCollapsed = ref(false);
    const currentModule = ref(0);
    
    const menuItems = [
      { label: '走货匹配拆解', icon: '🔗' },
      { label: '订单明细录入', icon: '📋' },
      { label: '货柜计划登记', icon: '🚢' },
      { label: '工厂下线数据', icon: '🏭' },
      { label: '质检验货数据', icon: '🔍' },
    ];
    
    // Preset tables config
    const presetTables = [
      { name: 'HAHS-2026年圣诞树1号', token: 'HrsRsQsMuhvxbOtTRahcKK3Yn4b', sheets: [
        { id: '20698c', name: '2026年订单走货计划表' },
        { id: 'htYQQ5', name: '7月走货' },
      ]},
      { name: 'JSPCWY-2026年常5号', token: 'Xt3QsCUPvhBTLktzczKcdrCpnUf', sheets: [
        { id: 'aq6vFK', name: '2026年订单走货计划表' },
      ]},
    ];
    const shippingPlanTable = { name: '走船计划表', token: 'shtcnjG4qXxYltHvcYNYTujyNrg', sheets: { plan26: 'Ocj58O', plan8: 'eOEmuF' } };
    
    // ===== Module 1: 走货匹配拆解 =====
    const mod1 = reactive({
      step: 1,
      // 代理设置
      proxyUrl: localStorage.getItem('feishu_proxy_url') || '',
      proxyStatus: '',
      proxyExpanded: false,
      proxyLoading: false,
      targetToken: localStorage.getItem('feishu_target_token') || '',
      targetSheetId: localStorage.getItem('feishu_target_sheet_id') || '',
      // 订单明细表数据源
      orderTable: '',
      orderSheetId: '',
      orderUrl: '',
      orderFile: null,
      orderFileName: '',
      orderSource: '',
      orderSourceDesc: '',
      // 走货明细表数据源
      shippingTable: '',
      shippingSheetId: '',
      shippingUrl: '',
      shippingFile: null,
      shippingFileName: '',
      shippingSource: '',
      shippingSourceDesc: '',
      // 数据
      loading: false,
      shippingData: [],
      orderData: [],
      result: null,
      // 确认执行状态
      confirmed: false,
      confirmedAction: '',
      confirmedText: '',
    });

    const orderFileInput = ref(null);
    const shippingFileInput = ref(null);

    // ===== 飞书代理相关函数 =====
    function testProxy() {
      if (!mod1.proxyUrl) { alert('请先输入代理地址'); return; }
      mod1.proxyLoading = true;
      mod1.proxyStatus = '';
      fetch(mod1.proxyUrl.replace(/\/$/, '') + '/health')
        .then(r => r.json())
        .then(d => { mod1.proxyStatus = d.status === 'ok' ? 'ok' : 'fail'; })
        .catch(() => { mod1.proxyStatus = 'fail'; })
        .finally(() => { mod1.proxyLoading = false; });
    }

    function saveProxy() {
      localStorage.setItem('feishu_proxy_url', mod1.proxyUrl);
      localStorage.setItem('feishu_target_token', mod1.targetToken);
      localStorage.setItem('feishu_target_sheet_id', mod1.targetSheetId);
      alert('代理设置已保存');
    }

    async function fetchLarkSheet(proxyUrl, spreadsheetToken, sheetId) {
      const url = `${proxyUrl}/feishu-api/open-apis/sheets/v2/spreadsheets/${spreadsheetToken}/values/${sheetId}`;
      const resp = await fetch(url);
      const data = await resp.json();
      if (data.code === 0) {
        return data.data.valueRange.values;
      }
      throw new Error(data.msg || '读取飞书表失败');
    }

    function convertSheetToOrderData(rows) {
      if (!rows || rows.length < 2) return [];
      const headers = rows[0].map(h => String(h || '').trim());
      const findColIndex = (keywords) => {
        for (let i = 0; i < headers.length; i++) {
          for (const kw of keywords) {
            if (headers[i].includes(kw)) return i;
          }
        }
        return -1;
      };
      const contractIdx = findColIndex(['合同号', '合同']);
      const containerIdx = findColIndex(['货柜号', '货柜']);
      const skuIdx = findColIndex(['SKU', 'sku', '型号']);
      const qtyIdx = findColIndex(['数量', '走货数量', '计划走货数量']);
      const deadlineIdx = findColIndex(['交期', '货好时间', '交货日期']);
      const shippingIdx = findColIndex(['船期', '开船时间', '计划开船时间']);

      const result = [];
      for (let i = 1; i < rows.length; i++) {
        const row = rows[i];
        if (!row || row.length === 0) continue;
        const sku = skuIdx >= 0 ? String(row[skuIdx] || '') : '';
        const qty = qtyIdx >= 0 ? parseInt(row[qtyIdx]) || 0 : 0;
        if (!sku || qty <= 0) continue;
        result.push({
          contract: contractIdx >= 0 ? String(row[contractIdx] || '') : '',
          container: containerIdx >= 0 ? String(row[containerIdx] || '') : '',
          sku: sku,
          qty: qty,
          deadline: deadlineIdx >= 0 ? String(row[deadlineIdx] || '') : '',
          shipping: shippingIdx >= 0 ? String(row[shippingIdx] || '') : '',
        });
      }
      return result;
    }

    function convertSheetToShippingData(rows) {
      if (!rows || rows.length < 2) return [];
      const headers = rows[0].map(h => String(h || '').trim());
      const findColIndex = (keywords) => {
        for (let i = 0; i < headers.length; i++) {
          for (const kw of keywords) {
            if (headers[i].includes(kw)) return i;
          }
        }
        return -1;
      };
      const containerIdx = findColIndex(['货柜号', '货柜']);
      const skuIdx = findColIndex(['SKU', 'sku', '型号']);
      const qtyIdx = findColIndex(['计划走货数量', '走货数量', '数量']);
      const dateIdx = findColIndex(['计划开船时间', '开船时间', '船期']);

      const result = [];
      for (let i = 1; i < rows.length; i++) {
        const row = rows[i];
        if (!row || row.length === 0) continue;
        const sku = skuIdx >= 0 ? String(row[skuIdx] || '') : '';
        const container = containerIdx >= 0 ? String(row[containerIdx] || '') : '';
        if (!sku || !container) continue;
        result.push({
          container: container,
          sku: sku,
          qty: qtyIdx >= 0 ? parseInt(row[qtyIdx]) || 0 : 0,
          date: dateIdx >= 0 ? String(row[dateIdx] || '') : '',
        });
      }
      return result;
    }

    async function fetchOrderFromProxy() {
      if (!mod1.proxyUrl) return false;
      let token = '', sheetId = '';
      if (mod1.orderTable && mod1.orderSheetId) {
        token = mod1.orderTable;
        sheetId = mod1.orderSheetId;
      } else if (mod1.orderUrl) {
        const match = mod1.orderUrl.match(/\/spreadsheets\/([A-Za-z0-9]+)/);
        if (match) token = match[1];
        sheetId = mod1.orderSheetId || '';
      }
      if (!token || !sheetId) return false;
      try {
        mod1.orderSource = 'feishu';
        mod1.orderSourceDesc = `飞书表 / Sheet:${sheetId} (通过代理读取中...)`;
        const rows = await fetchLarkSheet(mod1.proxyUrl.replace(/\/$/, ''), token, sheetId);
        mod1.orderData = convertSheetToOrderData(rows);
        mod1.orderSourceDesc = `飞书表 / Sheet:${sheetId} (${mod1.orderData.length}条)`;
        mod1.proxyStatus = 'ok';
        return true;
      } catch (e) {
        mod1.orderSourceDesc = `读取失败: ${e.message}`;
        mod1.proxyStatus = 'fail';
        return false;
      }
    }

    async function fetchShippingFromProxy() {
      if (!mod1.proxyUrl) return false;
      let token = '', sheetId = '';
      if (mod1.shippingTable && mod1.shippingSheetId) {
        token = mod1.shippingTable;
        sheetId = mod1.shippingSheetId;
      } else if (mod1.shippingUrl) {
        const match = mod1.shippingUrl.match(/\/spreadsheets\/([A-Za-z0-9]+)/);
        if (match) token = match[1];
        sheetId = mod1.shippingSheetId || '';
      }
      if (!token || !sheetId) return false;
      try {
        mod1.shippingSource = 'feishu';
        mod1.shippingSourceDesc = `飞书表 / Sheet:${sheetId} (通过代理读取中...)`;
        const rows = await fetchLarkSheet(mod1.proxyUrl.replace(/\/$/, ''), token, sheetId);
        mod1.shippingData = convertSheetToShippingData(rows);
        mod1.shippingSourceDesc = `飞书表 / Sheet:${sheetId} (${mod1.shippingData.length}条)`;
        mod1.proxyStatus = 'ok';
        return true;
      } catch (e) {
        mod1.shippingSourceDesc = `读取失败: ${e.message}`;
        mod1.proxyStatus = 'fail';
        return false;
      }
    }

    // 检查两个数据源是否都已配置
    const mod1Ready = computed(() => {
      const orderReady = (mod1.orderTable && mod1.orderSheetId) || mod1.orderUrl || mod1.orderFile;
      const shippingReady = (mod1.shippingTable && mod1.shippingSheetId) || mod1.shippingUrl || mod1.shippingFile;
      return orderReady && shippingReady;
    });

    // 根据选中的预设表，计算可选的sheet列表
    const mod1OrderSheetOptions = computed(() => {
      if (!mod1.orderTable) return [];
      const table = presetTables.find(t => t.token === mod1.orderTable);
      return table ? table.sheets : [];
    });

    const mod1ShippingSheetOptions = computed(() => {
      if (!mod1.shippingTable) return [];
      const table = presetTables.find(t => t.token === mod1.shippingTable);
      return table ? table.sheets : [];
    });

    // 选择预设表时的回调
    function onOrderTableChange() {
      mod1.orderUrl = '';
      mod1.orderSheetId = '';
      mod1.orderFile = null;
      mod1.orderFileName = '';
      mod1.orderSource = '';
      mod1.orderSourceDesc = '';
      mod1.orderData = [];
      // 如果该表只有一个sheet，自动选中
      const opts = mod1OrderSheetOptions.value;
      if (opts.length === 1) {
        mod1.orderSheetId = opts[0].id;
        updateOrderSourceDesc();
      }
      // 如果代理已配置，自动通过代理读取数据
      if (mod1.proxyUrl && mod1.orderTable && mod1.orderSheetId) {
        fetchOrderFromProxy();
      }
    }

    function onShippingTableChange() {
      mod1.shippingUrl = '';
      mod1.shippingSheetId = '';
      mod1.shippingFile = null;
      mod1.shippingFileName = '';
      mod1.shippingSource = '';
      mod1.shippingSourceDesc = '';
      mod1.shippingData = [];
      const opts = mod1ShippingSheetOptions.value;
      if (opts.length === 1) {
        mod1.shippingSheetId = opts[0].id;
        updateShippingSourceDesc();
      }
      // 如果代理已配置，自动通过代理读取数据
      if (mod1.proxyUrl && mod1.shippingTable && mod1.shippingSheetId) {
        fetchShippingFromProxy();
      }
    }

    // URL输入回调：尝试自动提取sheet ID
    function onOrderUrlChange() {
      mod1.orderTable = '';
      mod1.orderFile = null;
      mod1.orderFileName = '';
      mod1.orderData = [];
      // 尝试从URL提取sheet参数
      const match = mod1.orderUrl.match(/[?&]sheet=([^&#]+)/);
      if (match) {
        mod1.orderSheetId = match[1];
      }
      updateOrderSourceDesc();
      // 如果代理已配置且有URL和sheetId，自动通过代理读取
      if (mod1.proxyUrl && mod1.orderUrl && mod1.orderSheetId) {
        fetchOrderFromProxy();
      }
    }

    function onShippingUrlChange() {
      mod1.shippingTable = '';
      mod1.shippingFile = null;
      mod1.shippingFileName = '';
      mod1.shippingData = [];
      const match = mod1.shippingUrl.match(/[?&]sheet=([^&#]+)/);
      if (match) {
        mod1.shippingSheetId = match[1];
      }
      updateShippingSourceDesc();
      // 如果代理已配置且有URL和sheetId，自动通过代理读取
      if (mod1.proxyUrl && mod1.shippingUrl && mod1.shippingSheetId) {
        fetchShippingFromProxy();
      }
    }

    // 更新数据源描述
    function updateOrderSourceDesc() {
      if (mod1.orderTable && mod1.orderSheetId) {
        const table = presetTables.find(t => t.token === mod1.orderTable);
        const sheet = table ? table.sheets.find(s => s.id === mod1.orderSheetId) : null;
        mod1.orderSource = 'feishu';
        mod1.orderSourceDesc = `${table ? table.name : mod1.orderTable} / ${sheet ? sheet.name : mod1.orderSheetId}`;
      } else if (mod1.orderUrl) {
        mod1.orderSource = 'feishu_link';
        mod1.orderSourceDesc = mod1.orderSheetId ? `飞书链接 / Sheet:${mod1.orderSheetId}` : '飞书链接';
      } else if (mod1.orderFile) {
        mod1.orderSource = 'excel';
        mod1.orderSourceDesc = '本地Excel: ' + mod1.orderFileName;
      } else {
        mod1.orderSource = '';
        mod1.orderSourceDesc = '';
      }
    }

    function updateShippingSourceDesc() {
      if (mod1.shippingTable && mod1.shippingSheetId) {
        const table = presetTables.find(t => t.token === mod1.shippingTable);
        const sheet = table ? table.sheets.find(s => s.id === mod1.shippingSheetId) : null;
        mod1.shippingSource = 'feishu';
        mod1.shippingSourceDesc = `${table ? table.name : mod1.shippingTable} / ${sheet ? sheet.name : mod1.shippingSheetId}`;
      } else if (mod1.shippingUrl) {
        mod1.shippingSource = 'feishu_link';
        mod1.shippingSourceDesc = mod1.shippingSheetId ? `飞书链接 / Sheet:${mod1.shippingSheetId}` : '飞书链接';
      } else if (mod1.shippingFile) {
        mod1.shippingSource = 'excel';
        mod1.shippingSourceDesc = '本地Excel: ' + mod1.shippingFileName;
      } else {
        mod1.shippingSource = '';
        mod1.shippingSourceDesc = '';
      }
    }

    // 订单明细表上传处理
    function triggerOrderUpload() {
      if (orderFileInput.value) orderFileInput.value.click();
    }

    function handleOrderSelect(e) {
      const file = e.target.files[0];
      if (file) parseOrderExcel(file);
    }

    function handleOrderDrop(e) {
      const file = e.dataTransfer.files[0];
      if (file) parseOrderExcel(file);
    }

    function parseOrderExcel(file) {
      mod1.orderFile = file;
      mod1.orderFileName = file.name;
      mod1.orderTable = '';
      mod1.orderUrl = '';
      mod1.orderSheetId = '';
      mod1.orderSource = 'excel';
      mod1.orderSourceDesc = '本地Excel: ' + file.name;
      const reader = new FileReader();
      reader.onload = function(e) {
        try {
          const data = new Uint8Array(e.target.result);
          const workbook = XLSX.read(data, { type: 'array' });
          const firstSheet = workbook.Sheets[workbook.SheetNames[0]];
          const jsonData = XLSX.utils.sheet_to_json(firstSheet, { defval: '' });
          if (jsonData.length > 0) {
            mod1.orderData = jsonData.map(row => {
              const headers = Object.keys(row);
              const findCol = (keywords) => {
                for (const h of headers) {
                  for (const kw of keywords) {
                    if (h.includes(kw)) return row[h];
                  }
                }
                return '';
              };
              return {
                contract: findCol(['合同号', '合同']),
                container: findCol(['货柜号', '货柜']),
                sku: findCol(['SKU', 'sku', '型号']),
                qty: parseInt(findCol(['数量', '走货数量', '计划走货数量'])) || 0,
                deadline: findCol(['交期', '货好时间', '交货日期']),
                shipping: findCol(['船期', '开船时间', '计划开船时间']),
              };
            }).filter(r => r.sku && r.qty > 0);
          }
        } catch (err) {
          console.warn('Excel解析失败:', err);
        }
      };
      reader.readAsArrayBuffer(file);
    }

    // 走货明细表上传处理
    function triggerShippingUpload() {
      if (shippingFileInput.value) shippingFileInput.value.click();
    }

    function handleShippingSelect(e) {
      const file = e.target.files[0];
      if (file) parseShippingExcel(file);
    }

    function handleShippingDrop(e) {
      const file = e.dataTransfer.files[0];
      if (file) parseShippingExcel(file);
    }

    function parseShippingExcel(file) {
      mod1.shippingFile = file;
      mod1.shippingFileName = file.name;
      mod1.shippingTable = '';
      mod1.shippingUrl = '';
      mod1.shippingSheetId = '';
      mod1.shippingSource = 'excel';
      mod1.shippingSourceDesc = '本地Excel: ' + file.name;
      const reader = new FileReader();
      reader.onload = function(e) {
        try {
          const data = new Uint8Array(e.target.result);
          const workbook = XLSX.read(data, { type: 'array' });
          const firstSheet = workbook.Sheets[workbook.SheetNames[0]];
          const jsonData = XLSX.utils.sheet_to_json(firstSheet, { defval: '' });
          if (jsonData.length > 0) {
            mod1.shippingData = jsonData.map(row => {
              const headers = Object.keys(row);
              const findCol = (keywords) => {
                for (const h of headers) {
                  for (const kw of keywords) {
                    if (h.includes(kw)) return row[h];
                  }
                }
                return '';
              };
              return {
                container: findCol(['货柜号', '货柜']),
                sku: findCol(['SKU', 'sku', '型号']),
                qty: parseInt(findCol(['计划走货数量', '走货数量', '数量'])) || 0,
                date: findCol(['计划开船时间', '开船时间', '船期']),
              };
            }).filter(r => r.sku && r.container);
          }
        } catch (err) {
          console.warn('Excel解析失败:', err);
        }
      };
      reader.readAsArrayBuffer(file);
    }

    // 执行拆解：匹配 + 校验逻辑
    async function mod1Execute() {
      // 如果代理已配置，先通过代理获取数据
      if (mod1.proxyUrl) {
        mod1.loading = true;
        let orderOk = true, shippingOk = true;
        // 如果订单数据尚未通过代理加载，尝试加载
        if (mod1.orderSource !== 'excel' && mod1.orderData.length === 0) {
          orderOk = await fetchOrderFromProxy();
        }
        // 如果走货数据尚未通过代理加载，尝试加载
        if (mod1.shippingSource !== 'excel' && mod1.shippingData.length === 0) {
          shippingOk = await fetchShippingFromProxy();
        }
        if (!orderOk && mod1.orderData.length === 0) {
          alert('订单数据读取失败，请检查代理设置和数据源配置');
          mod1.loading = false;
          return;
        }
        if (!shippingOk && mod1.shippingData.length === 0) {
          alert('走货数据读取失败，请检查代理设置和数据源配置');
          mod1.loading = false;
          return;
        }
      } else {
        // 无代理时，仅支持本地 Excel
        if (mod1.orderSource !== 'excel' || mod1.shippingSource !== 'excel') {
          alert('未配置飞书代理，请先配置代理地址，或上传本地 Excel 文件。\n\n飞书表数据无法在浏览器中直接读取，请：\n1. 配置飞书代理后重试，或\n2. 将飞书表导出为 Excel 后上传');
          return;
        }
      }

      // 检查数据是否已解析
      if (mod1.orderData.length === 0 || mod1.shippingData.length === 0) {
        alert('数据解析失败或数据为空，请重新配置数据源');
        mod1.loading = false;
        return;
      }

      // 使用用户实际数据执行拆解匹配
      const shippingData = mod1.shippingData;
      const orderData = mod1.orderData;

      const errors = [];
      const items = [];
      
      shippingData.forEach((s, i) => {
        const order = orderData.find(o => o.sku === s.sku && o.container === s.container);
        if (order) {
          if (s.qty === order.qty) {
            items.push({
              contract: order.contract,
              container: s.container,
              sku: s.sku,
              shippingQty: s.qty,
              orderQty: order.qty,
            });
            errors.push({ valid: true, message: `${s.container} / ${s.sku} 匹配成功`, type: '正常' });
          } else {
            errors.push({
              valid: false,
              field: `${s.container} / ${s.sku}`,
              message: `走货数量(${s.qty})与订单数量(${order.qty})不一致`,
              type: '数量不匹配'
            });
          }
        } else {
          errors.push({
            valid: false,
            field: `${s.container} / ${s.sku}`,
            message: `在订单明细表中未找到匹配的SKU`,
            type: '未匹配'
          });
        }
      });

      const errorList = errors.filter(e => !e.valid);
      const errorCount = errorList.length;
      const successCount = items.length;
      const totalCount = shippingData.length;

      mod1.result = {
        totalCount: totalCount,
        successCount: successCount,
        errorCount: errorCount,
        verified: errorCount === 0,
        items: items,
        errors: errorList,
      };

      mod1.loading = false;
      mod1.step = 2;
      mod1.confirmed = false;
      mod1.confirmedAction = '';
      mod1.confirmedText = '';
    }

    async function mod1ConfirmLark() {
      if (!mod1.result || mod1.result.errorCount > 0) return;

      // 如果代理已配置且有目标表信息，直接通过代理写入飞书表
      if (mod1.proxyUrl && mod1.targetToken && mod1.targetSheetId) {
        mod1.loading = true;
        try {
          const values = [
            ['合同号', '货柜号', 'SKU', '走货数量', '订单数量']
          ];
          mod1.result.items.forEach(item => {
            values.push([item.contract, item.container, item.sku, item.shippingQty, item.orderQty]);
          });

          const proxyUrl = mod1.proxyUrl.replace(/\/$/, '');
          const writeUrl = `${proxyUrl}/feishu-api/open-apis/sheets/v2/spreadsheets/${mod1.targetToken}/values`;
          const resp = await fetch(writeUrl, {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              valueRange: {
                range: mod1.targetSheetId,
                values: values
              }
            })
          });
          const data = await resp.json();
          if (data.code === 0) {
            mod1.confirmedText = `✅ 已成功写入飞书表！\n目标表: ${mod1.targetToken}\nSheet: ${mod1.targetSheetId}\n写入 ${values.length - 1} 条数据`;
            mod1.confirmedAction = 'lark';
            mod1.confirmed = true;
            mod1.proxyStatus = 'ok';
          } else {
            throw new Error(data.msg || '写入失败');
          }
        } catch (e) {
          alert('写入飞书表失败: ' + e.message + '\n\n请检查代理地址、目标表 Token 和 Sheet ID 是否正确。');
          mod1.proxyStatus = 'fail';
        }
        mod1.loading = false;
        return;
      }

      // 代理未配置时，生成飞书写入指令文本（原有逻辑）
      const lines = ['【走货拆解执行指令】'];
      lines.push('请在飞书订单明细表中执行以下拆解结果写入：');
      lines.push('');
      lines.push('合同号 | 货柜号 | SKU | 走货数量 | 订单数量');
      lines.push('--- | --- | --- | --- | ---');
      mod1.result.items.forEach(item => {
        lines.push(`${item.contract} | ${item.container} | ${item.sku} | ${item.shippingQty} | ${item.orderQty}`);
      });
      lines.push('');
      lines.push(`总计 ${mod1.result.items.length} 条数据，守恒校验已通过。`);
      
      const text = lines.join('\n');
      mod1.confirmedText = text;
      mod1.confirmedAction = 'lark';
      mod1.confirmed = true;
      
      // 复制到剪贴板
      navigator.clipboard.writeText(text).catch(() => {
        // 剪贴板 API 失败时不阻断流程，用户可手动复制
      });
    }

    function mod1ConfirmExport() {
      mod1Export();
      mod1.confirmedAction = 'export';
      mod1.confirmed = true;
    }

    function mod1Export() {
      if (!mod1.result || !mod1.result.items || mod1.result.items.length === 0) {
        alert('没有可导出的数据');
        return;
      }
      const exportData = mod1.result.items.map(item => ({
        '合同号': item.contract,
        '货柜号': item.container,
        'SKU': item.sku,
        '走货数量': item.shippingQty,
        '订单数量': item.orderQty,
      }));
      const ws = XLSX.utils.json_to_sheet(exportData);
      ws['!cols'] = [{ wch: 12 }, { wch: 18 }, { wch: 15 }, { wch: 12 }, { wch: 12 }];
      const wb = XLSX.utils.book_new();
      XLSX.utils.book_append_sheet(wb, ws, '拆解结果');
      const now = new Date();
      const ts = now.getFullYear() + String(now.getMonth()+1).padStart(2,'0') + String(now.getDate()).padStart(2,'0') + '_' + String(now.getHours()).padStart(2,'0') + String(now.getMinutes()).padStart(2,'0');
      XLSX.writeFile(wb, '拆解结果_订单明细_' + ts + '.xlsx');
    }

    function mod1Reset() {
      mod1.step = 1;
      mod1.orderTable = '';
      mod1.orderSheetId = '';
      mod1.orderUrl = '';
      mod1.orderFile = null;
      mod1.orderFileName = '';
      mod1.orderSource = '';
      mod1.orderSourceDesc = '';
      mod1.shippingTable = '';
      mod1.shippingSheetId = '';
      mod1.shippingUrl = '';
      mod1.shippingFile = null;
      mod1.shippingFileName = '';
      mod1.shippingSource = '';
      mod1.shippingSourceDesc = '';
      mod1.shippingData = [];
      mod1.orderData = [];
      mod1.result = null;
      mod1.confirmed = false;
      mod1.confirmedAction = '';
      mod1.confirmedText = '';
    }

    // ===== Module 2: 订单明细录入 =====
    const mod2 = reactive({
      step: 1,
      selectedTable: '',
      customUrl: '',
      fileName: '',
      parsedData: [],
      headers: [],
      fieldMapping: [],
      result: null,
    });
    const fileInput = ref(null);

    function triggerFileUpload() {
      if (fileInput.value) fileInput.value.click();
    }

    function handleFileSelect(e) {
      const file = e.target.files[0];
      if (file) parseExcelFile(file);
    }

    function handleFileDrop(e) {
      const file = e.dataTransfer.files[0];
      if (file) parseExcelFile(file);
    }

    function parseExcelFile(file) {
      mod2.fileName = file.name;
      const reader = new FileReader();
      reader.onload = function(e) {
        try {
          const data = new Uint8Array(e.target.result);
          const workbook = XLSX.read(data, { type: 'array' });
          const firstSheet = workbook.Sheets[workbook.SheetNames[0]];
          const jsonData = XLSX.utils.sheet_to_json(firstSheet, { defval: '' });
          
          if (jsonData.length > 0) {
            mod2.headers = Object.keys(jsonData[0]);
            mod2.parsedData = jsonData;
            mod2.step = 2;
            // Auto field mapping
            const fieldMap = { '合同号': 'contract', 'SKU': 'sku', '数量': 'qty', '交期': 'deadline', '货柜号': 'container' };
            mod2.fieldMapping = mod2.headers.filter(h => fieldMap[h]).map(h => ({ from: h, to: fieldMap[h] }));
          }
        } catch (err) {
          alert('文件解析失败: ' + err.message);
        }
      };
      reader.readAsArrayBuffer(file);
    }

    function mod2Preview() {
      mod2.step = 3;
    }

    function mod2Confirm() {
      mod2.step = 4;
      const successCount = mod2.parsedData.length - Math.floor(mod2.parsedData.length * 0.05);
      const failedCount = mod2.parsedData.length - successCount;
      mod2.result = {
        success: successCount,
        failed: failedCount,
        total: mod2.parsedData.length,
        failedDetails: failedCount > 0 ? Array.from({ length: failedCount }, (_, i) => ({
          row: Math.floor(Math.random() * mod2.parsedData.length) + 1,
          reason: ['SKU不存在', '数量格式错误', '合同号不匹配'][i % 3],
        })) : [],
      };
    }

    function mod2Reset() {
      mod2.step = 1;
      mod2.selectedTable = '';
      mod2.customUrl = '';
      mod2.fileName = '';
      mod2.parsedData = [];
      mod2.headers = [];
      mod2.fieldMapping = [];
      mod2.result = null;
      if (fileInput.value) fileInput.value.value = '';
    }

    // ===== Module 3: 货柜计划登记 =====
    const mod3 = reactive({
      step: 1,
      loading: false,
      previewed: false,
      planData: [],
      result: null,
    });

    function mod3Load() {
      mod3.loading = true;
      setTimeout(() => {
        mod3.planData = [
          { id: 'GC-2026-0801', factory: 'HAHS', shipping: '2026-08-15', method: '海运', port: '深圳', cutoff: '2026-08-10', inspection: '2026-08-08', actual: '待确认', loading: '2026-08-12', booking: '2026-08-05' },
          { id: 'GC-2026-0802', factory: 'JSPCWY', shipping: '2026-08-20', method: '海运', port: '厦门', cutoff: '2026-08-15', inspection: '2026-08-13', actual: '待确认', loading: '2026-08-17', booking: '2026-08-10' },
          { id: 'GC-2026-0803', factory: 'HAHS', shipping: '2026-08-25', method: '陆运', port: '深圳', cutoff: '2026-08-22', inspection: '2026-08-20', actual: '待确认', loading: '2026-08-23', booking: '2026-08-18' },
          { id: 'GC-2026-0804', factory: 'JSPCWY', shipping: '2026-09-01', method: '海运', port: '厦门', cutoff: '2026-08-27', inspection: '2026-08-25', actual: '待确认', loading: '2026-08-29', booking: '2026-08-22' },
        ];
        mod3.loading = false;
        mod3.step = 2;
        mod3.previewed = false;
      }, 1500);
    }

    function mod3Preview() {
      mod3.previewed = true;
    }

    function mod3Confirm() {
      mod3.step = 3;
      mod3.result = { success: true, message: '' };
    }

    function mod3Reset() {
      mod3.step = 1;
      mod3.planData = [];
      mod3.result = null;
      mod3.previewed = false;
    }

    // ===== Module 4: 工厂下线数据 =====
    const mod4 = reactive({
      step: 1,
      selectedTable: '',
      inputText: '',
      validationResults: [],
      result: null,
    });

    const mod4ValidCount = computed(() => mod4.validationResults.filter(r => r.valid).length);
    const mod4InvalidCount = computed(() => mod4.validationResults.filter(r => !r.valid).length);

    function mod4Parse() {
      const lines = mod4.inputText.split('\n').filter(l => l.trim());
      mod4.validationResults = lines.map(line => {
        const trimmed = line.trim();
        const regex = /^([A-Za-z0-9]+)-([A-Za-z0-9]+)-(\d+)$/;
        const match = trimmed.match(regex);
        if (match) {
          return { raw: trimmed, valid: true, contract: match[1], sku: match[2], qty: parseInt(match[3]) };
        }
        let error = '格式不正确';
        if (!trimmed.includes('-')) error = '缺少分隔符"-"';
        else if (trimmed.split('-').length !== 3) error = '应包含3个字段：合同号-SKU-数量';
        else {
          const parts = trimmed.split('-');
          if (!/^\d+$/.test(parts[2])) error = '数量必须为数字，当前为: "' + parts[2] + '"';
        }
        return { raw: trimmed, valid: false, error };
      });
      mod4.step = 3;
    }

    function mod4Validate() {
      // Already validated during parse, just advance step
      if (mod4ValidCount.value > 0) mod4.step = 4;
    }

    function mod4Confirm() {
      const validItems = mod4.validationResults.filter(r => r.valid);
      const failCount = validItems.length > 0 ? Math.floor(Math.random() * 2) : 0;
      mod4.result = {
        success: validItems.length - failCount,
        failed: failCount,
      };
    }

    function mod4Reset() {
      mod4.step = 1;
      mod4.selectedTable = '';
      mod4.inputText = '';
      mod4.validationResults = [];
      mod4.result = null;
    }

    // ===== Module 5: 质检验货数据 =====
    const mod5 = reactive({
      step: 1,
      selectedTable: '',
      inputText: '',
      validationResults: [],
      result: null,
      remainderSummary: [],
    });

    const mod5ValidCount = computed(() => mod5.validationResults.filter(r => r.valid).length);
    const mod5InvalidCount = computed(() => mod5.validationResults.filter(r => !r.valid).length);

    function mod5Parse() {
      const lines = mod5.inputText.split('\n').filter(l => l.trim());
      mod5.validationResults = lines.map(line => {
        const trimmed = line.trim();
        // Match: SU-{合同号}-{SKU}-{数量}套 [尾数{N}套]
        const regex = /^SU-([A-Za-z0-9]+)-([A-Za-z0-9]+)-(\d+)套(?:[，,\s]*尾数(\d+)套)?$/;
        const match = trimmed.match(regex);
        if (match) {
          return {
            raw: trimmed, valid: true,
            contract: match[1], sku: match[2],
            qty: parseInt(match[3]),
            remainder: match[4] ? parseInt(match[4]) : null,
          };
        }
        let error = '格式不正确';
        if (!trimmed.startsWith('SU-')) error = '应以"SU-"开头';
        else if (trimmed.split('-').length < 4) error = '字段不足，格式应为 SU-合同号-SKU-数量套';
        else if (!trimmed.includes('套')) error = '数量后缺少"套"字';
        else {
          const parts = trimmed.split('-');
          const qtyPart = parts[3] || '';
          if (!/^\d+套/.test(qtyPart)) error = '数量格式错误，应为数字+套';
        }
        return { raw: trimmed, valid: false, error };
      });
      mod5.step = 3;
    }

    function mod5Validate() {
      if (mod5ValidCount.value > 0) {
        mod5.remainderSummary = mod5.validationResults
          .filter(r => r.valid && r.remainder)
          .map(r => ({ contract: r.contract, sku: r.sku, remainder: r.remainder }));
        mod5.step = 4;
      }
    }

    function mod5Confirm() {
      const validItems = mod5.validationResults.filter(r => r.valid);
      const failCount = validItems.length > 0 ? Math.floor(Math.random() * 2) : 0;
      mod5.result = {
        success: validItems.length - failCount,
        failed: failCount,
      };
    }

    function mod5Reset() {
      mod5.step = 1;
      mod5.selectedTable = '';
      mod5.inputText = '';
      mod5.validationResults = [];
      mod5.result = null;
      mod5.remainderSummary = [];
    }

    return {
      sidebarCollapsed, currentModule, menuItems,
      presetTables, shippingPlanTable,
      // Module 1
      mod1, mod1Ready, mod1OrderSheetOptions, mod1ShippingSheetOptions,
      orderFileInput, shippingFileInput,
      onOrderTableChange, onOrderUrlChange, onShippingTableChange, onShippingUrlChange,
      triggerOrderUpload, handleOrderSelect, handleOrderDrop,
      triggerShippingUpload, handleShippingSelect, handleShippingDrop,
      mod1Execute, mod1Reset, mod1Export, mod1ConfirmLark, mod1ConfirmExport,
      testProxy, saveProxy,
      // Module 2
      mod2, fileInput, triggerFileUpload, handleFileSelect, handleFileDrop,
      mod2Preview, mod2Confirm, mod2Reset,
      // Module 3
      mod3, mod3Load, mod3Preview, mod3Confirm, mod3Reset,
      // Module 4
      mod4, mod4ValidCount, mod4InvalidCount,
      mod4Parse, mod4Validate, mod4Confirm, mod4Reset,
      // Module 5
      mod5, mod5ValidCount, mod5InvalidCount,
      mod5Parse, mod5Validate, mod5Confirm, mod5Reset,
    };
  }
});

try { app.use(antd.default || antd); } catch(e) { console.warn('Antd init skipped:', e); }
app.mount('#app');
</script>
</body>
